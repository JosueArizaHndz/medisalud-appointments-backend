      "item": [
        {
          "name": "Listar Todos los Doctores",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/doctors",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["doctors"]
            }
          }
        },
        {
          "name": "Obtener Doctor por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/doctors/{{doctorId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["doctors", "{{doctorId}}"]
            }
          }
        },
        {
          "name": "Crear Doctor",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.id) {",
                  "    pm.collectionVariables.set('doctorId', jsonData.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Dr. Carlos Rodríguez\",\n  \"email\": \"carlos.rodriguez@medisalud.com\",\n  \"specialty\": \"CARDIOLOGY\",\n  \"licenseNumber\": \"MED-99999\",\n  \"maxPatients\": 150\n}"
            },
            "url": {
