    {
      "name": "03 - Citas Médicas",
      "item": [
        {
          "name": "Listar Todas las Citas",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/appointments",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["appointments"]
            }
          }
        },
        {
          "name": "Listar Citas con Filtros",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/appointments?doctorId={{doctorId}}&status=PROGRAMADA",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["appointments"],
              "query": [
                {"key": "doctorId", "value": "{{doctorId}", "enabled": true},
                {"key": "patientId", "value": "", "enabled": false},
                {"key": "status", "value": "PROGRAMADA", "enabled": true},
                {"key": "startDate", "value": "", "enabled": false},
                {"key": "endDate", "value": "", "enabled": false}
              ]
            }
          }
        },
        {
          "name": "Obtener Cita por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/appointments/{{appointmentId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["appointments", "{{appointmentId}}"]
            }
          }
        },
        {
          "name": "Citas por Doctor",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/appointments/doctor/{{doctorId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["appointments", "doctor", "{{doctorId}}"]
            }
          }
        },
        {
          "name": "Citas por Paciente",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/appointments/patient/{{patientId}}",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["appointments", "patient", "{{patientId}}"]
            }
          }
        },
        {
          "name": "Citas por Fecha",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/appointments/date?date=2026-07-15",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["appointments", "date"],
              "query": [
                {"key": "date", "value": "2026-07-15"}
              ]
            }
          }
        },
        {
          "name": "Crear Cita Médica",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.id) {",
                  "    pm.collectionVariables.set('appointmentId', jsonData.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": \"{{patientId}}\",\n  \"doctorId\": \"{{doctorId}}\",\n  \"appointmentDate\": \"2026-07-15T10:00:00\",\n  \"notes\": \"Consulta de control anual\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/appointments",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["appointments"]
            }
          }
        },
        {
          "name": "Cancelar Cita",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/appointments/{{appointmentId}}/cancel",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["appointments", "{{appointmentId}}", "cancel"]
            }
          }
        },
        {
          "name": "Reprogramar Cita",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.data && jsonData.data.id) {",
                  "    pm.collectionVariables.set('appointmentId', jsonData.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/appointments/{{appointmentId}}/reschedule?newDate=2026-07-16T14:00:00",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["appointments", "{{appointmentId}}", "reschedule"],
              "query": [
                {"key": "newDate", "value": "2026-07-16T14:00:00"}
              ]
            }
          }
        }
      ]
